generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  company   String?
  message   String
  source    String   @default("website")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
